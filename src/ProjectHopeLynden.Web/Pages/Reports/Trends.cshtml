@page
@using ProjectHopeLynden.Application.Inventory
@model TrendsModel
@{
    ViewData["Title"] = Model.PageTitle;
    var groupingLabel = Model.Report.Request.Grouping == InventoryTrendGrouping.Category ? "Category" : "Item";
}
<link rel="stylesheet" href="~/css/trend-report.css" />

<section class="hero hero--branded trend-report-hero">
    <p class="eyebrow">Project Hope Food Bank of Lynden</p>
    <h1>@Model.PageTitle</h1>
    <p>@Model.Summary</p>
</section>

<section class="card trend-filter-card" aria-label="Inventory trend report filters">
    <form method="get" class="trend-filter-form">
        <label>
            <span>Group results by</span>
            <select id="groupBy" name="groupBy">
                @if (Model.GroupBy == "category")
                {
                    <option value="item">Item</option>
                    <option value="category" selected>Category</option>
                }
                else
                {
                    <option value="item" selected>Item</option>
                    <option value="category">Category</option>
                }
            </select>
        </label>

        <label>
            <span>Item name</span>
            <input id="itemName" name="itemName" value="@Model.ItemName" placeholder="All items" autocomplete="off" />
        </label>

        <label>
            <span>Category</span>
            <select id="categoryId" name="categoryId">
                <option value="">All categories</option>
                @foreach (var category in Model.Categories)
                {
                    if (category.Id == Model.CategoryId)
                    {
                        <option value="@category.Id" selected>@category.Name</option>
                    }
                    else
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                }
            </select>
        </label>

        <label>
            <span>Inventory type</span>
            <select id="inventoryType" name="inventoryType">
                @if (Model.InventoryType == "commodity")
                {
                    <option value="all">All inventory</option>
                    <option value="commodity" selected>Commodity only</option>
                    <option value="noncommodity">Non-Commodity only</option>
                }
                else if (Model.InventoryType == "noncommodity")
                {
                    <option value="all">All inventory</option>
                    <option value="commodity">Commodity only</option>
                    <option value="noncommodity" selected>Non-Commodity only</option>
                }
                else
                {
                    <option value="all" selected>All inventory</option>
                    <option value="commodity">Commodity only</option>
                    <option value="noncommodity">Non-Commodity only</option>
                }
            </select>
        </label>

        <button type="submit">Generate report</button>
    </form>
</section>

<section class="card trend-report-summary">
    <div>
        <p class="card__kicker">Corrected trend datasets</p>
        <h2>Inventory snapshots and recorded movement by @groupingLabel.ToLowerInvariant()</h2>
        <p>Generated @Model.Report.GeneratedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</p>
    </div>
    <button type="button" class="print-report-button" onclick="window.print()">Print report</button>
</section>

@if (!Model.Report.HasData)
{
    <section class="card trend-empty" aria-live="polite">
        <h2>No historical count records found</h2>
        <p>Adjust the item, category, or inventory-type filters and generate the report again.</p>
    </section>
}
else
{
    <section class="card trend-report-table-card" aria-label="End-of-day inventory report results">
        <div class="section-heading">
            <p class="card__kicker">Inventory level</p>
            <h2>End-of-day inventory</h2>
            <p>A row appears only when the selected item or category had a recorded count. Entries not recounted that day retain their latest earlier quantity.</p>
        </div>

        @if (!Model.Report.HasInventorySnapshots)
        {
            <p>No end-of-day inventory snapshots match these filters.</p>
        }
        else
        {
            <div class="table-wrapper">
                <table class="inventory-table trend-report-table">
                    <thead>
                        <tr>
                            <th scope="col">Date</th>
                            <th scope="col">@groupingLabel</th>
                            <th scope="col">End-of-Day Quantity</th>
                            <th scope="col">Entries Included</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var point in Model.Report.InventorySnapshots)
                        {
                            <tr>
                                <td>@point.CountedOnUtc.ToString("yyyy-MM-dd")</td>
                                <td>@point.GroupName</td>
                                <td>@point.EndOfDayQuantity.ToString("0.##")</td>
                                <td>@point.InventoryEntryCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="card trend-report-table-card" aria-label="Daily count activity report results">
        <div class="section-heading">
            <p class="card__kicker">Recorded activity</p>
            <h2>Daily count activity</h2>
            <p>Only operational count updates with a known previous quantity are treated as movement. Imported starting counts establish the baseline and are not counted as activity.</p>
        </div>

        @if (!Model.Report.HasCountActivity)
        {
            <p>No operational count activity matches these filters yet.</p>
        }
        else
        {
            <div class="table-wrapper">
                <table class="inventory-table trend-report-table">
                    <thead>
                        <tr>
                            <th scope="col">Date</th>
                            <th scope="col">@groupingLabel</th>
                            <th scope="col">Net Change</th>
                            <th scope="col">Count Events</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var point in Model.Report.CountActivity)
                        {
                            <tr>
                                <td>@point.CountedOnUtc.ToString("yyyy-MM-dd")</td>
                                <td>@point.GroupName</td>
                                <td>@point.NetQuantityChange.GetValueOrDefault().ToString("+0.##;-0.##;0")</td>
                                <td>@point.CountEventCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <p class="trend-report-note">Imported spreadsheet counts are inventory baselines. New quantity updates create the movement records shown here.</p>
    </section>

    <section class="card trend-report-note" aria-label="Historical classification note">
        <strong>Historical classification:</strong>
        Item, category, location, and Commodity status are stored with each new count. Records created before this correction are backfilled from the inventory entry's current classification because earlier classifications cannot be reconstructed from the original database.
    </section>
}
