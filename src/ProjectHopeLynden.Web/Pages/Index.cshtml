@page
@model IndexModel
@{
  ViewData["Title"] = Model.PageTitle;
}

<section class="hero hero--branded">
  <p class="eyebrow">Project Hope Food Bank of Lynden</p>
  <h1>@Model.PageTitle</h1>
  <p>@Model.Summary</p>
  <p class="hero__supporting-text">@Model.ImpactStatement</p>
</section>

<section class="dashboard-heading" aria-labelledby="dashboard-title">
  <p class="card__kicker">Inventory tools</p>
  <h2 id="dashboard-title">Choose a task</h2>
  <p>Open the tool you need for today&apos;s food-bank work.</p>
</section>

<section class="card-grid dashboard-grid" aria-label="Inventory tasks">
  @foreach (var card in Model.TaskCards)
  {
    var cardClasses = card.IsFeatured
      ? "card card--featured dashboard-card"
      : "card dashboard-card";

    <article class="@cardClasses">
      <p class="card__kicker">@card.Kicker</p>
      <h2>@card.Title</h2>
      <p>@card.Description</p>
      <p class="dashboard-card__action">
        <a class="button-link" asp-page="@card.Page">@card.ActionText</a>
      </p>
    </article>
  }
</section>
